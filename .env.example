# Copy this file to `.env` before running the app:  cp .env.example .env

# PostgreSQL connection string.
# Local: a local Postgres, OR just reuse a free Neon database (neon.tech).
# Production (Vercel): set this in Project → Settings → Environment Variables.
# Use the DIRECT (non-pooled) Neon URL so `prisma db push` works.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign portal session cookies.
# Change this to a strong random value in production.
AUTH_SECRET="dev-only-change-me-in-production-please-32chars"
